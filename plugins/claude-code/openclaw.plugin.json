{
  "id": "claude-code",
  "name": "Claude Code",
  "description": "Delegates coding tasks to Claude Code CLI (file editing, bash commands, session continuity).",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "claudePath":     { "type": "string" },
      "defaultWorkdir": { "type": "string" },
      "permissionMode": { "type": "string",
                          "enum": ["default","acceptEdits","bypassPermissions","dontAsk","plan"] },
      "timeoutMs":      { "type": "number" }
    }
  }
}
